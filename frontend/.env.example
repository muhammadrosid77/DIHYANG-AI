# DIHYANG AI — Frontend Environment Variables
# Copy file ini menjadi '.env' di folder frontend dan sesuaikan nilainya jika diperlukan.

# URL endpoint dasar API Backend (Default untuk server produksi FastAPI lokal)
# Kosongkan jika ingin menggunakan bawaan Vite proxy (/api) saat development.
# VITE_API_URL=http://localhost:8000/api
